# ==============================================================================                                                                     
# BreakBase Backend Environment Variables                                                                                                            
# ==============================================================================                                                                     
                                                                                                                                                       
# --- REQUIRED (backend will not start without these) ---                                                                                            
   
DATABASE_URL="postgresql://postgres:password@localhost:5432/breakbase?schema=public"                                                                 
JWT_SECRET="your-jwt-secret-here"                         
RPC_URL="https://sepolia.base.org"                                                                                                                   
ORACLE_PRIVATE_KEY="0x_your_oracle_private_key"
ANTHROPIC_API_KEY="sk-ant-your-anthropic-key"                                                                                                        
                                                                                                                                                       
# --- APP CONFIG ---                                                                                                                                 
                                                                                                                                                       
APP_PORT=3700                                             
NODE_ENV=development
JWT_EXPIRES_IN=7d
CHAIN_ID=84532                                                                                                                                       
APP_URL="http://localhost:3000"
API_URL="http://localhost:3700"                                                                                                                      
                                                            
# --- CONTRACT ADDRESSES (from deploy script output) ---

CHALLENGE_FACTORY_ADDRESS="0x_your_challenge_factory_address"                                                                                        
FEE_DISTRIBUTOR_ADDRESS="0x_your_fee_distributor_address"
REPUTATION_ORACLE_ADDRESS="0x_your_reputation_oracle_address"                                                                                        
USDC_ADDRESS="0x036CbD53842c5426634e7929541eC2318f3dCF7e" 
EAS_ADDRESS="0x4200000000000000000000000000000000000021"                                                                                             
   
# --- EAS ATTESTATION SCHEMAS (from deploy script output) ---                                                                                        
                                                            
SCHEMA_REGISTRY_ADDRESS="0x4200000000000000000000000000000000000020"                                                                                 
ATTACKER_SCHEMA_UID="0x_your_attacker_schema_uid"         
DEFENDER_SCHEMA_UID="0x_your_defender_schema_uid"
AUDIT_SCHEMA_UID="0x_your_audit_schema_uid"                                                                                                          
   
# --- COINBASE CDP (from https://portal.cdp.coinbase.com) ---                                                                                        
                                                            
CDP_API_KEY_ID="your_cdp_api_key_id"                                                                                                                 
CDP_API_KEY_SECRET="your_cdp_api_key_secret"
CDP_WALLET_SECRET="your_cdp_wallet_secret"                                                                                                           
CDP_AGENT_ADDRESS="0x_your_agent_wallet_address"          
# CDP_PAYMASTER_URL auto-generated from CDP_API_KEY_ID if not set                                                                                    
# CDP_WEBHOOK_SECRET="your_cdp_webhook_secret"
                                                                                                                                                       
# --- LLM / AI (Anthropic is required, others optional for multi-LLM) ---                                                                            
   
# OPENAI_API_KEY="sk-your-openai-key"                                                                                                                
# GOOGLE_GENERATIVE_AI_API_KEY="your-google-ai-key"       
# TOGETHER_API_KEY="your-together-key"
DEFAULT_AI_MODEL="anthropic:claude-sonnet-4-20250514"                                                                                                
# JUDGE_AI_MODEL="anthropic:claude-sonnet-4-20250514"
                                                                                                                                                       
# --- x402 PAYMENT PROTOCOL ---                           

# X402_FACILITATOR_URL="https://x402.org/facilitator"                                                                                                
X402_PAY_TO_ADDRESS="0x_your_payment_receiving_address"
                                                                                                                                                       
# --- FARCASTER (optional, enables webhook verification + agent posting) ---

# NEYNAR_API_KEY="your-neynar-api-key"                                                                                                               
# NEYNAR_MANAGER_SIGNER="your-neynar-manager-signer"
# AGENT_FID="your-agent-farcaster-id"                                                                                                                
                                                            
# --- COINBASE VERIFICATION (defaults work for Base Sepolia) ---                                                                                     
   
