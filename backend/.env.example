# EAS_GRAPHQL_URL="https://base-sepolia.easscan.org/graphql"                                                                                         
   
# --- WORKERS (defaults are fine) ---                                                                                                                
                                                            
# EVENT_INDEXER_INTERVAL_MS=15000                                                                                                                    
# PROTOCOL_AGENT_INTERVAL="*/10 * * * *"                  
# CHALLENGE_EXPIRY_CHECK_INTERVAL="*/5 * * * *"
# ORACLE_SIGNATURE_DEADLINE_SECONDS=3600                                                                                                             
   
# --- BUILDER CODE ---                                                                                                                               
                                                            
BUILDER_CODE="breakbase"